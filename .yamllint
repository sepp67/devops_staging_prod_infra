---
extends: default

ignore: |
  .git/
  .github/
  .venv/
  venv/
  node_modules/

rules:
  document-start: disable

  line-length:
    max: 160
    level: warning

  truthy:
    allowed-values:
      - "true"
      - "false"
    check-keys: false

  comments:
    min-spaces-from-content: 1

  indentation:
    indent-sequences: consistent
