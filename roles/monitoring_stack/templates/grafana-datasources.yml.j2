apiVersion: 1

deleteDatasources:
  - name: Prometheus
    orgId: 1
  - name: Loki
    orgId: 1

datasources:
  - name: {{ monitoring_stack_grafana_prometheus_datasource_name }}
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: {{ (monitoring_stack_grafana_default_datasource == monitoring_stack_grafana_prometheus_datasource_name) | lower }}
    editable: true
    jsonData:
      httpMethod: POST

  - name: {{ monitoring_stack_grafana_loki_datasource_name }}
    uid: loki
    type: loki
    access: proxy
    url: http://loki:3100
    isDefault: {{ (monitoring_stack_grafana_default_datasource == monitoring_stack_grafana_loki_datasource_name) | lower }}
    editable: true
