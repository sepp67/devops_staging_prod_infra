apiVersion: 1

datasources:
  - name: {{ monitoring_observability_grafana_prometheus_datasource_name }}
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: {{ (monitoring_observability_grafana_default_datasource == monitoring_observability_grafana_prometheus_datasource_name) | lower }}
    editable: true

  - name: {{ monitoring_observability_grafana_loki_datasource_name }}
    type: loki
    access: proxy
    url: http://loki:3100
    isDefault: {{ (monitoring_observability_grafana_default_datasource == monitoring_observability_grafana_loki_datasource_name) | lower }}
    editable: true
