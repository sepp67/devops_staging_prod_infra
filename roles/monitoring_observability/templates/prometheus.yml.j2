global:
  scrape_interval: {{ monitoring_observability_prometheus_scrape_interval }}
  evaluation_interval: {{ monitoring_observability_prometheus_evaluation_interval }}

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - 127.0.0.1:9090

  - job_name: node
    file_sd_configs:
      - files:
          - /etc/prometheus/file_sd/node_targets/*.yml

  - job_name: blackbox-http
    metrics_path: /probe
    params:
      module: [{{ monitoring_observability_blackbox_module }}]
    file_sd_configs:
      - files:
          - /etc/prometheus/file_sd/blackbox_targets/*.yml
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115
