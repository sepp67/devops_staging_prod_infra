server:
  http_listen_port: {{ monitoring_promtail_http_port }}
  grpc_listen_port: {{ monitoring_promtail_grpc_port }}

positions:
  filename: {{ monitoring_promtail_positions_file }}

clients:
  - url: {{ monitoring_loki_url | to_json }}

scrape_configs:
  - job_name: {{ monitoring_promtail_system_job_name | to_json }}
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ monitoring_promtail_system_job_name | to_json }}
          host: {{ monitoring_promtail_labels.host | to_json }}
          environment: {{ monitoring_promtail_labels.environment | to_json }}
          project: {{ monitoring_promtail_labels.project | to_json }}
          role: {{ monitoring_promtail_labels.role | to_json }}
          __path__: /var/log/*.log

{% if monitoring_promtail_all_log_paths | length > 0 %}
  - job_name: {{ monitoring_promtail_custom_job_name | to_json }}
    static_configs:
{% for path in monitoring_promtail_all_log_paths %}
      - targets:
          - localhost
        labels:
          job: {{ monitoring_promtail_custom_job_name | to_json }}
          host: {{ monitoring_promtail_labels.host | to_json }}
          environment: {{ monitoring_promtail_labels.environment | to_json }}
          project: {{ monitoring_promtail_labels.project | to_json }}
          role: {{ monitoring_promtail_labels.role | to_json }}
          __path__: {{ path | to_json }}
{% endfor %}
{% endif %}

{% if monitoring_promtail_extra_scrape_configs | length > 0 %}
{% for scrape in monitoring_promtail_extra_scrape_configs %}
  - {{ scrape | to_nice_yaml(indent=4) | indent(4, true) | trim }}
{% endfor %}
{% endif %}
