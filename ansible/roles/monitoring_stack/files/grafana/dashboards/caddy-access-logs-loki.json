{
  "uid": "caddy-access-loki",
  "title": "Caddy Access Logs (Loki)",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["devops", "showcase", "caddy", "loki"],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"caddy\"}, host)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests (logs/min)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"caddy\", host=~\"$host\"}[1m]))"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Latest Caddy access logs",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"caddy\", host=~\"$host\"}"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    }
  ]
}
