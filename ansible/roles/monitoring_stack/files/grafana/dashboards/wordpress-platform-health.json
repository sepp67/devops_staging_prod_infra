{
  "uid": "wp-platform-health",
  "title": "WordPress Platform Health",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["devops", "showcase", "wordpress", "blackbox"],
  "templating": {
    "list": [
      {
        "name": "site",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(probe_success{job=\"blackbox-http\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Uptime (probe_success)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(probe_success{job=\"blackbox-http\", instance=~\"$site\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      }
    },
    {
      "type": "timeseries",
      "title": "Probe duration (s)",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{job=\"blackbox-http\", instance=~\"$site\"}"
        }
      ],
      "fieldConfig": { "defaults": {} }
    },
    {
      "type": "timeseries",
      "title": "HTTP status code",
      "gridPos": { "x": 0, "y": 5, "w": 8, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_http_status_code{job=\"blackbox-http\", instance=~\"$site\"}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "SSL: days until cert expiry",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-http\", instance=~\"$site\"} - time()) / 86400"
        }
      ]
    }
  ]
}
