server:
  http_listen_port: {{ promtail_http_port }}
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
  - job_name: caddy_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: caddy
          host: {{ promtail_host_label }}
          __path__: /var/log/caddy/*.log

  - job_name: system_logs
    static_configs:
      - targets:
          - localhost
        labels:
          job: syslog
          host: {{ promtail_host_label }}
          __path__: /var/log/*.log
