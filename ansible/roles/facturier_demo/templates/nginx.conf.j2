server {
    listen 80;
    server_name _;

    charset utf-8;

    location = / {
        root /usr/share/nginx/html/vitrine;
        try_files /index.html =404;
    }

    location / {
        root /usr/share/nginx/html/vitrine;
        try_files $uri $uri/ /index.html;
    }

    location = /app {
        return 301 /app/;
    }

    location /app/ {
        alias /usr/share/nginx/html/app/;
        index index.html;
        try_files $uri $uri/ /app/index.html;
    }
}
