from fastapi import FastAPI
from fastapi.responses import JSONResponse
import os

app = FastAPI(title="Facturier Demo API", version="0.1.0")


@app.get("/api/health")
def health():
    return {
        "status": "ok",
        "app_env": os.getenv("FACTURIER_ENV", "unknown"),
        "generation_enabled": os.getenv("FACTURIER_ENABLE_GENERATION", "false"),
    }


@app.get("/api/info")
def info():
    return {
        "name": "facturier-demo",
        "mode": os.getenv("FACTURIER_ENV", "unknown"),
    }
