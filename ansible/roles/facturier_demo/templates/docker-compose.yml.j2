---
services:
  web:
    image: nginx:stable-alpine
    container_name: facturier-web
    restart: unless-stopped
    ports:
      - "{{ facturier_web_port }}:80"
    volumes:
      - ./web/vitrine:/usr/share/nginx/html/vitrine:ro
      - ./web/app:/usr/share/nginx/html/app:ro
      - ./web/nginx.conf:/etc/nginx/conf.d/default.conf:ro

  api:
    build:
      context: ./api
      dockerfile: Dockerfile
    container_name: facturier-api
    restart: unless-stopped
    ports:
      - "{{ facturier_api_port }}:8000"
    environment:
      FACTURIER_APP_NAME: "{{ facturier_project_name }}"
      FACTURIER_ENV: "{{ facturier_app_env }}"
      FACTURIER_ENABLE_GENERATION: "{{ facturier_enable_generation | ternary('true', 'false') }}"
      FACTURIER_INPUT_DIR: "/data/input"
      FACTURIER_OUTPUT_DIR: "/data/output"
      FACTURIER_TMP_DIR: "/data/tmp"
      FACTURIER_SCRIPTS_DIR: "/scripts"
    volumes:
      - ./data:/data
      - ./scripts:/scripts:ro
