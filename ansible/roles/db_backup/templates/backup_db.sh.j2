#!/bin/bash
set -euo pipefail

SITE="{{ site_name }}"
BACKUP_DIR="{{ db_backup_dir }}"
TODAY="$(date +%F)"
TS="$(date +%F_%H%M%S)"

DB_NAME="{{ secret.wp_db_name }}"
DB_USER="{{ secret.wp_db_user }}"
DB_PASS="{{ secret.wp_db_password }}"

DB_CONTAINER="${SITE}_db"
TODAY_PATTERN="${BACKUP_DIR}/${SITE}_${TODAY}_*.sql.gz"

mkdir -p "${BACKUP_DIR}"
chmod 700 "${BACKUP_DIR}"

# Reuse existing local backup if present, otherwise create one
if compgen -G "${TODAY_PATTERN}" > /dev/null; then
  OUT="$(ls -1 "${TODAY_PATTERN}" | head -n 1)"
  echo "Local backup for today already exists: ${OUT}"
else
  if ! docker ps --format '{{"{{"}}.Names{{"}}"}}' | grep -qx "${DB_CONTAINER}"; then
    echo "ERROR: DB container not running: ${DB_CONTAINER}" >&2
    exit 1
  fi

  OUT="${BACKUP_DIR}/${SITE}_${TS}.sql.gz}"

  docker exec "${DB_CONTAINER}" mariadb-dump -u"${DB_USER}" -p"${DB_PASS}" "${DB_NAME}" \
    | gzip > "${OUT}"

  echo "Created local backup: ${OUT}"
fi

# Rotation locale
find "${BACKUP_DIR}" -type f -name "${SITE}_*.sql.gz" -mtime +{{ db_backup_retention_days }} -delete

# Copy to NAS via temporary NFS mount
{% if db_backup_nfs_enabled and db_backup_copy_to_nas %}
NAS_DIR="{{ db_backup_nfs_mountpoint }}"
NAS_SRC="{{ db_backup_nfs_server }}:{{ db_backup_nfs_export }}"
NAS_FILE="${NAS_DIR}/$(basename "${OUT}")"

mkdir -p "${NAS_DIR}"

cleanup() {
  if mountpoint -q "${NAS_DIR}"; then
    umount "${NAS_DIR}"
  fi
}

trap cleanup EXIT

if ! mountpoint -q "${NAS_DIR}"; then
  mount -t nfs "${NAS_SRC}" "${NAS_DIR}"
fi

if [ -f "${NAS_FILE}" ]; then
  echo "Backup already present on NAS: ${NAS_FILE}"
else
  install -m 600 "${OUT}" "${NAS_DIR}/"
  echo "Copied backup to NAS: ${NAS_FILE}"
fi
{% endif %}